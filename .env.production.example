# OPE-FX Production Environment Variables
# Copy this file to .env.production and fill in your values.
# Never commit real secrets to version control.

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Authentication (Clerk) ────────────────────────────────────────────────────
CLERK_SECRET_KEY=sk_live_...
CLERK_PUBLISHABLE_KEY=pk_live_...

# ── Frontend (baked in at Vite build time) ────────────────────────────────────
VITE_CLERK_PUBLISHABLE_KEY=pk_live_...

# ── File Storage (Cloudinary) ─────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Session ───────────────────────────────────────────────────────────────────
SESSION_SECRET=change_me_to_a_long_random_string

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=8080

# ── Optional ─────────────────────────────────────────────────────────────────
# Path to the built frontend files (defaults to artifacts/ope-fx/dist/public)
# FRONTEND_DIST_PATH=/absolute/path/to/artifacts/ope-fx/dist/public
# LOG_LEVEL=info
